# Optional runtime configuration for Axolot
# Copy to .env.local and export variables in your shell profile as needed.

# OpenClaw gateway endpoint
UPSTREAM_URL=http://127.0.0.1:18789

# Optional custom chat path for upstream providers
# Example: /v1/chat/completions
UPSTREAM_CHAT_PATH=

# Upstream model name
# Examples: gpt-5.4, gemini-*, grok-*, kimi-*, llama*/qwen* (via Ollama)
UPSTREAM_MODEL=openclaw

# Optional provider hint used to build provider/model ids when needed.
# Examples: openai-codex, openai, gemini, grok, kimi, ollama
UPSTREAM_PROVIDER=

# Ollama endpoint health-check (used when provider/model resolves to ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# When 1 (default), proxy sends ollama/* models directly to OLLAMA_BASE_URL
# without depending on OpenClaw for that hop.
AXOLOT_OLLAMA_DIRECT=1

# Upstream auth token (required only if your gateway enforces auth)
UPSTREAM_AUTH=

# Upstream auth header name:
# - authorization  -> sends "Bearer <token>"
# - x-api-key      -> sends "<token>"
UPSTREAM_AUTH_HEADER=authorization

# Security policy: only allow local upstream by default
# Set to 0 only if you intentionally use a remote upstream host.
AXOLOT_UPSTREAM_LOCAL_ONLY=1

# Optional profile selection from .axolotrc/.axolotrc.json
AXOLOT_PROFILE=

# Optional explicit config path (absolute or relative)
AXOLOT_CONFIG=

# Skills pack to preload (folder under ./skillpacks)
# Defaults to token-lean
AXOLOT_SKILLS_PACK=token-lean

# Optional fixed proxy port (launcher auto-selects a free port if omitted)
PROXY_PORT=

# Optional budget limit for each axolot run
# Equivalent to passing: axolot --max-budget-usd <value>
AXOLOT_MAX_BUDGET_USD=
